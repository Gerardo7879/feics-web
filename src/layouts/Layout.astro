---
import '../styles/global.css';
// Tipografías autoalojadas (antes Google Fonts): Poppins (títulos) e Inter (cuerpo)
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import { SITE } from '../config';

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL('/og.png', Astro.site).href;

/** Datos estructurados schema.org para resultados enriquecidos de Google. */
const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: 'FEICS — Foro Estudiantil de Investigación en Ciencias de la Salud',
  description: SITE.description,
  startDate: SITE.eventStartDateTime,
  endDate: SITE.eventDateISO,
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  image: [ogImageUrl],
  url: canonicalUrl,
  location: {
    '@type': 'Place',
    name: SITE.venue.name,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'León',
      addressRegion: 'Guanajuato',
      addressCountry: 'MX',
    },
  },
  organizer: {
    '@type': 'EducationalOrganization',
    name: 'Universidad de Guanajuato — División de Ciencias de la Salud, Departamento de Medicina y Nutrición',
    url: 'https://www.ugto.mx',
  },
};
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{SITE.title}</title>
    <meta name="description" content={SITE.description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="FEICS" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={SITE.title} />
    <meta property="og:description" content={SITE.description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="es_MX" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={SITE.title} />
    <meta name="twitter:description" content={SITE.description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Datos estructurados: evento -->
    <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />

  </head>
  <body>
    <a
      href="#inicio"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-navy focus:px-4 focus:py-2 focus:text-white"
    >
      Saltar al contenido principal
    </a>
    <slot />
  </body>
</html>
