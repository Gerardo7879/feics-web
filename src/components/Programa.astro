---
/**
 * Programa del evento. Estado actual: "Próximamente".
 * [EDITAR] Cuando el comité apruebe el programa detallado con horarios,
 * restaura aquí la línea de tiempo vertical.
 */
import SectionTitle from './SectionTitle.astro';
---

<section id="programa" class="scroll-mt-20 bg-card py-20 md:py-28">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <SectionTitle eyebrow="Agenda">
      Programa del <span class="text-gold-dark">foro</span>
    </SectionTitle>

    <div class="mx-auto mt-14 max-w-2xl rounded-2xl border border-dashed border-gold/50 bg-cream px-8 py-14 text-center">
      <span class="inline-block rounded-full bg-gold/15 px-4 py-1.5 text-sm font-bold uppercase tracking-brand text-gold-dark">
        Próximamente
      </span>
      <p class="mt-5 text-lg leading-relaxed text-secondary">
        El programa detallado, con horarios y actividades, se publicará
        próximamente en esta página.
      </p>
    </div>
  </div>
</section>
