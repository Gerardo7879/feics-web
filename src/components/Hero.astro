---
/**
 * Sección de bienvenida: logo oficial, nombre de la edición, lema con
 * palabras alternadas marino/dorado, cuenta regresiva y botones de acción.
 */
import { SITE } from '../config';
import ContourLines from './ContourLines.astro';
---

<section id="inicio" class="relative overflow-hidden scroll-mt-20">
  <ContourLines class="right-0 top-0 -translate-y-1/4 translate-x-1/4" />
  <ContourLines class="bottom-0 left-0 translate-y-1/4 -translate-x-1/4 rotate-180" />

  <!-- Isotipo "F" como marca de agua sutil -->
  <img
    src="/logos/logo-feics-f.png"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute -right-16 top-1/2 hidden w-[26rem] -translate-y-1/2 opacity-[0.05] lg:block"
  />

  <div class="relative mx-auto flex max-w-4xl flex-col items-center px-4 pb-24 pt-32 text-center sm:px-6 md:pb-32 md:pt-40">
    <!-- Logo oficial FEICS -->
    <img
      src="/logos/logo-feics-completo.png"
      alt="Logotipo del FEICS: isotipo en forma de F en azul marino y dorado sobre las siglas FEICS"
      width="431"
      height="427"
      class="h-32 w-auto md:h-40"
      fetchpriority="high"
    />

    <!-- Badges: fecha/sede + evento gratuito -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <p class="inline-flex items-center gap-2 rounded-full border border-gold/40 bg-gold/10 px-4 py-1.5 text-sm font-medium text-navy">
        <svg class="h-4 w-4 text-gold-dark" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M6 2a1 1 0 0 0-1 1v1H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1V3a1 1 0 1 0-2 0v1H7V3a1 1 0 0 0-1-1Zm0 5a1 1 0 0 0 0 2h8a1 1 0 1 0 0-2H6Z" clip-rule="evenodd" />
        </svg>
        <time datetime={SITE.eventDateISO}>{SITE.eventDate}</time>
        <span aria-hidden="true">·</span>
        <span>Campus León, UG</span>
      </p>
      <p class="inline-flex items-center gap-2 rounded-full border border-navy/15 bg-navy/5 px-4 py-1.5 text-sm font-semibold text-navy">
        Evento gratuito
      </p>
    </div>

    <h1 class="mt-6 font-heading text-3xl font-bold leading-tight text-navy sm:text-4xl md:text-5xl">
      {SITE.eventName}
      <span class="mt-2 block text-xl font-semibold text-gold-dark sm:text-2xl">
        {SITE.eventShortName}
      </span>
    </h1>

    <p class="mt-5 font-heading text-lg font-semibold sm:text-xl">
      <span class="text-navy">Investigación.</span>{' '}
      <span class="text-gold-dark">Innovación.</span>{' '}
      <span class="text-navy">Impacto.</span>
    </p>

    <!-- Cuenta regresiva al inicio del foro -->
    <!-- `invisible` (no `hidden`) para reservar el espacio y evitar
         layout shift cuando el script muestra la cuenta. -->
    <div
      id="cuenta-regresiva"
      class="invisible mt-8 flex gap-3 sm:gap-4"
      role="timer"
      aria-label="Tiempo restante para el inicio del foro"
    >
      {
        [
          { id: 'cr-dias', etiqueta: 'días' },
          { id: 'cr-horas', etiqueta: 'horas' },
          { id: 'cr-minutos', etiqueta: 'min' },
        ].map((unidad) => (
          <div class="flex w-20 flex-col items-center rounded-2xl border border-navy/10 bg-card py-3 sm:w-24">
            <span id={unidad.id} class="font-heading text-2xl font-bold tabular-nums text-navy sm:text-3xl">
              --
            </span>
            <span class="mt-0.5 text-xs font-medium uppercase tracking-widest text-secondary">
              {unidad.etiqueta}
            </span>
          </div>
        ))
      }
    </div>

    <div class="mt-10 flex flex-col gap-4 sm:flex-row">
      <a
        href={SITE.formUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-navy px-8 py-3.5 font-semibold text-white transition-colors hover:bg-secondary"
      >
        Registrarme
      </a>
      <a
        href="#convocatoria"
        class="rounded-full border-2 border-navy px-8 py-3.5 font-semibold text-navy transition-colors hover:border-gold-dark hover:text-gold-dark"
      >
        Enviar un trabajo
      </a>
    </div>
  </div>
</section>

<script>
  import { SITE } from '../config';

  const MS_POR_MINUTO = 60_000;
  const MS_POR_HORA = 3_600_000;
  const MS_POR_DIA = 86_400_000;

  const contenedor = document.getElementById('cuenta-regresiva');
  const celdas = {
    dias: document.getElementById('cr-dias'),
    horas: document.getElementById('cr-horas'),
    minutos: document.getElementById('cr-minutos'),
  };
  const inicioForo = new Date(SITE.eventStartDateTime).getTime();

  function actualizarCuenta() {
    const restante = inicioForo - Date.now();
    if (!contenedor || !celdas.dias || !celdas.horas || !celdas.minutos) return;
    if (restante <= 0) {
      // El foro ya comenzó: se retira la cuenta para no mostrar ceros.
      contenedor.remove();
      return;
    }
    celdas.dias.textContent = String(Math.floor(restante / MS_POR_DIA));
    celdas.horas.textContent = String(Math.floor((restante % MS_POR_DIA) / MS_POR_HORA));
    celdas.minutos.textContent = String(Math.floor((restante % MS_POR_HORA) / MS_POR_MINUTO));
    contenedor.classList.remove('invisible');
  }

  actualizarCuenta();
  window.setInterval(actualizarCuenta, MS_POR_MINUTO);
</script>
