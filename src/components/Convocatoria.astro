---
/**
 * Convocatoria: lineamientos oficiales para el envío de trabajos libres.
 * Única modalidad: cartel científico con defensa oral.
 */
import { Image } from 'astro:assets';
import { SITE } from '../config';
import fotoCarteles from '../assets/feics-2025-01.jpg';

const requisitos = [
  {
    titulo: 'Del resumen',
    puntos: [
      'Formato Word (.docx), fuente Arial 11, alineación justificada.',
      'Extensión máxima de 400 palabras.',
      'Título en negritas, máximo 20 palabras.',
      'Máximo 5 autores, con adscripción y correo del autor de correspondencia.',
      'Estructura con encabezados: Introducción, Objetivos, Metodología (o Descripción del caso), Resultados y Discusión, Conclusiones.',
      'Evaluación anónima: no mencionar institución ni datos identificables.',
      'Número de aprobación del Comité de Ética en Investigación, cuando aplique.',
    ],
  },
  {
    titulo: 'Del cartel',
    puntos: [
      'Modalidad: cartel científico con defensa oral.',
      'Medidas: 90 × 120 cm, orientación vertical.',
      'Legible a un metro de distancia.',
    ],
  },
] as const;
---

<section id="convocatoria" class="scroll-mt-20">
  <!-- Banda con fotografía del FEICS 2025 y overlay marino -->
  <div class="relative overflow-hidden bg-navy text-white">
    <Image
      src={fotoCarteles}
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover"
      widths={[800, 1600]}
      sizes="100vw"
      format="webp"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-navy/85" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-4xl px-4 py-20 text-center sm:px-6 md:py-28">
      <p class="text-sm font-semibold uppercase tracking-brand text-gold">Convocatoria</p>
      <h2 class="mt-3 font-heading text-3xl font-semibold md:text-4xl">
        Lineamientos para el envío de <span class="text-gold">trabajos libres</span>
      </h2>
      <div class="mx-auto mt-5 h-0.5 w-16 rounded-full bg-gold" aria-hidden="true"></div>

      <p class="mx-auto mt-6 max-w-2xl leading-relaxed text-white/85">
        El {SITE.eventShortName} invita a estudiantes y profesionales de las
        licenciaturas en Medicina, Nutrición, Enfermería, Ciencias Biomédicas,
        Psicología y CAFYS (Ciencias de la Actividad Física y Salud), entre
        otras áreas de la salud, a enviar trabajos de investigación o
        reportes de caso clínico como trabajos libres.
      </p>

      <p class="mt-6 inline-flex flex-wrap items-center justify-center gap-2 rounded-full border border-gold/50 bg-gold/15 px-5 py-2 text-sm font-semibold">
        <svg class="h-4 w-4 text-gold" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm1-12a1 1 0 1 0-2 0v4c0 .3.1.5.3.7l2.8 2.9a1 1 0 0 0 1.4-1.4L11 9.6V6Z" clip-rule="evenodd" />
        </svg>
        Fecha límite: {SITE.abstractDeadline} · {SITE.abstractDeadlineTime}
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={`mailto:${SITE.contactEmail}?subject=Env%C3%ADo%20de%20trabajo%20libre%20%E2%80%94%20IV%20FEICS-UG`}
          class="rounded-full bg-gold px-8 py-3.5 font-bold text-navy transition-colors hover:bg-cream"
        >
          Enviar mi trabajo a {SITE.contactEmail}
        </a>
      </div>
    </div>
  </div>

  <!-- Requisitos de participación: bloque único (resumen + cartel), sin duplicar criterios -->
  <div class="bg-card py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <h3 class="font-heading text-xl font-semibold text-navy">Requisitos de participación</h3>

      <div class="mx-auto mt-6 grid gap-6 text-left sm:grid-cols-2">
        {
          requisitos.map((bloque) => (
            <article class="rounded-2xl border border-navy/10 bg-cream p-7">
              <h4 class="font-heading text-base font-semibold text-navy">{bloque.titulo}</h4>
              <ul class="mt-4 space-y-2.5" role="list">
                {bloque.puntos.map((punto) => (
                  <li class="flex gap-2.5 text-sm leading-relaxed text-secondary">
                    <svg class="mt-1 h-3.5 w-3.5 shrink-0 text-gold-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                    {punto}
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>

      <a
        href="/lineamientos-trabajos-libres-iv-feics.pdf"
        download
        target="_blank"
        rel="noopener"
        class="mt-8 inline-flex items-center gap-2 rounded-full bg-navy px-8 py-3.5 font-semibold text-white transition-colors hover:bg-secondary"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3v12m0 0 4-4m-4 4-4-4M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" />
        </svg>
        Descargar lineamientos (PDF)
      </a>

      <p class="mt-6 text-sm text-secondary">
        ¿Dudas sobre los lineamientos? Escríbenos a{' '}
        <a href={`mailto:${SITE.contactEmail}`} class="font-medium text-gold-dark underline-offset-4 hover:underline">
          {SITE.contactEmail}
        </a>
      </p>
    </div>
  </div>
</section>
