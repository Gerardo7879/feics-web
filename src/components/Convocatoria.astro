---
/**
 * Convocatoria: pasos para enviar carteles/trabajos y botón al Google Form.
 */
import { SITE } from '../config';
import ContourLines from './ContourLines.astro';

const pasos = [
  {
    titulo: 'Prepara tu resumen',
    detalle:
      'Redacta el resumen de tu trabajo o cartel según los lineamientos de la convocatoria (extensión, formato y eje temático).',
  },
  {
    titulo: 'Envía tu trabajo',
    detalle:
      'Completa el formulario y adjunta tu resumen antes de la fecha límite.',
  },
  {
    titulo: 'Recibe tu dictamen',
    detalle:
      'El comité científico evaluará tu trabajo y te notificará por correo si fue aceptado como presentación oral o cartel.',
  },
] as const;
---

<section id="convocatoria" class="relative scroll-mt-20 overflow-hidden bg-navy py-20 text-white md:py-28">
  <ContourLines class="right-0 top-0 -translate-y-1/3 translate-x-1/3" />

  <div class="relative mx-auto max-w-5xl px-4 text-center sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-brand text-gold">Convocatoria</p>
    <h2 class="mt-3 font-heading text-3xl font-semibold md:text-4xl">
      Presenta tu <span class="text-gold">investigación</span>
    </h2>
    <div class="mx-auto mt-5 h-0.5 w-16 rounded-full bg-gold" aria-hidden="true"></div>

    <p class="mx-auto mt-6 max-w-2xl leading-relaxed text-white/80">
      La convocatoria para enviar carteles y trabajos libres está abierta.
      <!-- [EDITAR] fecha límite de envío cuando se defina -->
      Fecha límite de envío: <strong class="text-gold">próximamente</strong>.
    </p>

    <ol class="mt-14 grid gap-6 text-left sm:grid-cols-3">
      {
        pasos.map((paso, indice) => (
          <li class="rounded-2xl border border-white/15 p-7">
            <span class="font-heading text-3xl font-bold text-gold" aria-hidden="true">
              {String(indice + 1).padStart(2, '0')}
            </span>
            <h3 class="mt-4 text-lg font-semibold">{paso.titulo}</h3>
            <p class="mt-2 text-sm leading-relaxed text-white/75">{paso.detalle}</p>
          </li>
        ))
      }
    </ol>

    <a
      href={SITE.trabajosFormUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-12 inline-block rounded-full bg-gold px-10 py-4 font-bold text-navy transition-colors hover:bg-cream"
    >
      Enviar mi trabajo
    </a>
  </div>
</section>
