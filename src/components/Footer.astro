---
/**
 * Pie de página institucional: logos oficiales, adscripción, redes y contacto.
 */
import { SITE } from '../config';

const anio = new Date().getFullYear();

/** Solo se muestran las redes con URL configurada en src/config.ts. */
const hayRedes = SITE.socials.facebook !== '' || SITE.socials.instagram !== '';
---

<footer id="contacto" class="scroll-mt-20 bg-navy py-16 text-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="grid gap-12 md:grid-cols-3">
      <!-- Marca -->
      <div>
        <!-- El logo lleva chip crema porque el isotipo es azul marino -->
        <span class="inline-block rounded-2xl bg-cream p-4">
          <img
            src="/logos/logo-feics-completo.png"
            alt="Logotipo del FEICS"
            width="431"
            height="427"
            class="h-24 w-auto"
            loading="lazy"
          />
        </span>
        <p class="mt-4 text-sm leading-relaxed text-white/70">
          <span class="text-white">Investigación.</span>
          <span class="text-gold">Innovación.</span>
          <span class="text-white">Impacto.</span>
        </p>
      </div>

      <!-- Institución -->
      <div>
        <div class="flex items-start gap-4">
          <img
            src="/logos/logo-ug.png"
            alt="Escudo de la Universidad de Guanajuato"
            width="336"
            height="400"
            class="h-16 w-auto shrink-0"
            loading="lazy"
          />
          <address class="text-sm not-italic leading-relaxed text-white/70">
            <strong class="font-semibold text-white">Universidad de Guanajuato</strong><br />
            Campus León<br />
            División de Ciencias de la Salud<br />
            Departamento de Medicina y Nutrición
          </address>
        </div>
        <img
          src="/logos/campus-leon-dcs-blanco.png"
          alt="Campus León, División de Ciencias de la Salud"
          width="1000"
          height="289"
          class="mt-6 w-64 max-w-full opacity-90"
          loading="lazy"
        />
        <!-- [PENDIENTE: logo CABMT] Espacio reservado para el logo del
             Cuerpo Académico en Biomedicina Traslacional. -->
        <p class="mt-4 inline-block rounded-lg border border-dashed border-white/25 px-4 py-2 text-xs text-white/50">
          Cuerpo Académico en Biomedicina Traslacional (CABMT)
        </p>
      </div>

      <!-- Contacto y redes -->
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-widest text-gold">Contacto</h2>
        <a
          href={`mailto:${SITE.contactEmail}`}
          class="mt-3 inline-block text-sm text-white/70 underline-offset-4 hover:text-gold hover:underline"
        >
          {SITE.contactEmail}
        </a>
        {
          hayRedes && (
            <ul class="mt-5 flex gap-4" role="list">
              {SITE.socials.facebook !== '' && (
                <li>
                  <a
                    href={SITE.socials.facebook}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Facebook del FEICS (se abre en pestaña nueva)"
                    class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/20 text-white/80 transition-colors hover:border-gold hover:text-gold"
                  >
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M13.5 21v-7h2.6l.4-3h-3V9.1c0-.9.3-1.5 1.6-1.5h1.5V4.9c-.3 0-1.2-.1-2.2-.1-2.2 0-3.7 1.3-3.7 3.8V11H8v3h2.7v7h2.8z" />
                    </svg>
                  </a>
                </li>
              )}
              {SITE.socials.instagram !== '' && (
                <li>
                  <a
                    href={SITE.socials.instagram}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Instagram del FEICS (se abre en pestaña nueva)"
                    class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/20 text-white/80 transition-colors hover:border-gold hover:text-gold"
                  >
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                      <rect x="3.5" y="3.5" width="17" height="17" rx="4.5" />
                      <circle cx="12" cy="12" r="4" />
                      <circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none" />
                    </svg>
                  </a>
                </li>
              )}
            </ul>
          )
        }
      </div>
    </div>

    <div class="mt-12 border-t border-white/15 pt-6 text-center text-xs text-white/50">
      © {anio} FEICS · {SITE.eventName} ({SITE.eventShortName}) ·
      Universidad de Guanajuato, Campus León
    </div>
  </div>
</footer>
