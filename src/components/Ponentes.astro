---
/**
 * Ponentes e invitados. Estado actual: "Próximamente".
 * [EDITAR] Cuando se confirmen los ponentes, restaura el grid de
 * tarjetas con foto, nombre y cargo (public/images/ponente-N.jpg).
 */
import SectionTitle from './SectionTitle.astro';
---

<section id="ponentes" class="scroll-mt-20 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionTitle eyebrow="Invitados">
      Ponentes del <span class="text-gold">evento</span>
    </SectionTitle>

    <div class="mx-auto mt-14 max-w-2xl rounded-2xl border border-dashed border-gold/50 bg-card px-8 py-14 text-center">
      <span class="inline-block rounded-full bg-gold/15 px-4 py-1.5 text-sm font-bold uppercase tracking-brand text-gold-dark">
        Próximamente
      </span>
      <p class="mt-5 text-lg leading-relaxed text-secondary">
        Estamos confirmando a los ponentes e invitados del foro.
        Muy pronto anunciaremos el cartel completo por aquí y en nuestras redes.
      </p>
    </div>
  </div>
</section>
