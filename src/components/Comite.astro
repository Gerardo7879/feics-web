---
/**
 * Comité Organizador del foro (CABMT y MIC) y Comité Estudiantil.
 */
import SectionTitle from './SectionTitle.astro';

const directiva = [
  { nombre: 'Dr. Marco Antonio Hernández Luna', cargo: 'Presidente', iniciales: 'MH' },
  { nombre: 'Dr. Sergio López Briones', cargo: 'Secretario', iniciales: 'SL' },
] as const;

const vocales = [
  { nombre: 'Dra. Esmeralda Rodríguez Miranda', iniciales: 'ER' },
  { nombre: 'Dra. Mayra Remedios Montecillo Aguado', iniciales: 'MM' },
  { nombre: 'Dra. Rebeca Monroy Torres', iniciales: 'RM' },
  { nombre: 'Dr. Benigno Linares Segovia', iniciales: 'BL' },
  { nombre: 'Dr. José A. de Jesús Álvarez Canales', iniciales: 'JA' },
] as const;

const estudiantil = [
  { nombre: 'Daniel Gonzalo Gómez Revilla Mancilla', iniciales: 'DG' },
  { nombre: 'Gerardo Ortiz Castro', iniciales: 'GO' },
  { nombre: 'Pamela Esqueda Aldrete', iniciales: 'PE' },
  { nombre: 'Valeria Ortega Albarrán', iniciales: 'VO' },
  { nombre: 'Víctor Julián Aguiñaga Caballero', iniciales: 'VA' },
  { nombre: 'Ana Sofía Iñigo Martínez', iniciales: 'AI' },
  { nombre: 'Luis Gabriel Gómez González', iniciales: 'LG' },
] as const;
---

<section id="comite" class="scroll-mt-20 bg-card py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionTitle eyebrow="Organización">
      Comité <span class="text-gold-dark">Organizador</span>
    </SectionTitle>

    <p class="mx-auto mt-6 max-w-2xl text-center leading-relaxed text-secondary">
      El FEICS es organizado por miembros del Cuerpo Académico en Biomedicina
      Traslacional (CABMT) y de la Maestría en Investigación Clínica (MIC).
    </p>

    <!-- Presidencia y secretaría -->
    <ul class="mx-auto mt-12 flex flex-wrap items-stretch justify-center gap-6" role="list">
      {
        directiva.map((persona) => (
          <li class="flex w-full sm:w-[calc(50%-0.75rem)] sm:max-w-xs">
            <div class="flex h-full w-full flex-col items-center rounded-2xl border border-gold/40 bg-cream p-7 text-center">
              <span class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-navy font-heading text-xl font-bold text-gold" aria-hidden="true">
                {persona.iniciales}
              </span>
              <h3 class="mt-4 font-semibold text-navy">{persona.nombre}</h3>
              <p class="mt-1 text-sm font-semibold uppercase tracking-widest text-gold-dark">{persona.cargo}</p>
            </div>
          </li>
        ))
      }
    </ul>

    <!-- Vocales -->
    <ul class="mt-6 flex flex-wrap items-stretch justify-center gap-6" role="list">
      {
        vocales.map((persona) => (
          <li class="flex w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]">
            <div class="flex h-full w-full flex-col items-center rounded-2xl border border-navy/10 bg-cream p-6 text-center">
              <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-navy font-heading font-bold text-gold" aria-hidden="true">
                {persona.iniciales}
              </span>
              <h3 class="mt-3 font-semibold text-navy">{persona.nombre}</h3>
              <p class="mt-1 text-xs font-semibold uppercase tracking-widest text-secondary">Vocal</p>
            </div>
          </li>
        ))
      }
    </ul>

    <!-- Comité Estudiantil -->
    <h3 class="mt-16 text-center font-heading text-xl font-semibold text-navy sm:mt-20">
      Comité Estudiantil
    </h3>
    <ul class="mx-auto mt-8 flex flex-wrap items-stretch justify-center gap-6" role="list">
      {
        estudiantil.map((persona) => (
          <li class="flex w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]">
            <div class="flex h-full w-full flex-col items-center rounded-2xl border border-navy/10 bg-cream p-6 text-center">
              <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-navy font-heading font-bold text-gold" aria-hidden="true">
                {persona.iniciales}
              </span>
              <h3 class="mt-3 font-semibold text-navy">{persona.nombre}</h3>
              <p class="mt-1 text-xs font-semibold uppercase tracking-widest text-secondary">Integrante</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
