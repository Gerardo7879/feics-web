---
/**
 * Preguntas frecuentes con acordeones nativos (details/summary) y
 * datos estructurados FAQPage. [EDITAR] Completa las respuestas
 * marcadas "se anunciará" cuando el comité defina esos detalles.
 */
import { SITE } from '../config';
import SectionTitle from './SectionTitle.astro';

const preguntas = [
  {
    pregunta: '¿Quién puede asistir al foro?',
    respuesta:
      'Estudiantes de ciencias de la salud y comunidad académica interesada en la investigación. El foro es organizado por la División de Ciencias de la Salud (Departamento de Medicina y Nutrición) de la Universidad de Guanajuato, Campus León.',
  },
  {
    pregunta: '¿Cómo me registro?',
    respuesta:
      'Con el botón "Registrarme" de esta página, que te lleva al formulario de registro en línea. El registro se confirma por correo electrónico.',
  },
  {
    pregunta: '¿Cómo envío un cartel o trabajo libre?',
    respuesta:
      'En la sección "Convocatoria" encontrarás el botón "Enviar mi trabajo" con el formulario de envío. Los lineamientos completos (extensión, formato y ejes temáticos) y la fecha límite se anunciarán en esta misma página.',
  },
  {
    pregunta: '¿El evento tiene costo?',
    respuesta:
      'Los detalles de inscripción y costos se anunciarán próximamente en esta página y en la convocatoria oficial.',
  },
  {
    pregunta: '¿Dónde y cuándo será?',
    respuesta: `El ${SITE.eventDate} en la ${SITE.venue.name}, ${SITE.venue.city}. El auditorio exacto se anunciará próximamente.`,
  },
  {
    pregunta: '¿Se entregará constancia de participación?',
    respuesta:
      'La información sobre constancias se anunciará junto con el programa final del foro.',
  },
] as const;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: preguntas.map((item) => ({
    '@type': 'Question',
    name: item.pregunta,
    acceptedAnswer: { '@type': 'Answer', text: item.respuesta },
  })),
};
---

<section id="faq" class="scroll-mt-20 bg-card py-20 md:py-28">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <SectionTitle eyebrow="Dudas">
      Preguntas <span class="text-gold-dark">frecuentes</span>
    </SectionTitle>

    <div class="mt-14 space-y-4">
      {
        preguntas.map((item) => (
          <details class="group rounded-2xl border border-navy/10 bg-cream px-6 py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-navy [&::-webkit-details-marker]:hidden">
              {item.pregunta}
              <svg
                class="h-5 w-5 shrink-0 text-gold-dark transition-transform group-open:rotate-180"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-secondary">{item.respuesta}</p>
          </details>
        ))
      }
    </div>

    <p class="mt-10 text-center text-sm text-secondary">
      ¿Tienes otra duda? Escríbenos a{' '}
      <a href={`mailto:${SITE.contactEmail}`} class="font-medium text-gold-dark underline-offset-4 hover:underline">
        {SITE.contactEmail}
      </a>
    </p>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
