---
/**
 * Preguntas frecuentes oficiales con acordeones nativos (details/summary)
 * navegables por teclado y datos estructurados FAQPage.
 */
import { SITE } from '../config';
import SectionTitle from './SectionTitle.astro';

const preguntas = [
  {
    pregunta: '¿Tiene costo asistir o participar?',
    respuesta: 'No. El foro es completamente gratuito: no hay cuota de asistencia ni de participación.',
  },
  {
    pregunta: '¿Quién puede enviar trabajos?',
    respuesta:
      'Estudiantes y profesionales de licenciaturas en Medicina, Nutrición, Enfermería, Ciencias Biomédicas, CAFYD y otras áreas de la salud.',
  },
  {
    pregunta: '¿Cuál es la fecha límite para enviar mi resumen?',
    respuesta: `El ${SITE.abstractDeadline} a las ${SITE.abstractDeadlineTime}, al correo ${SITE.contactEmail}.`,
  },
  {
    pregunta: '¿En qué modalidad se presenta?',
    respuesta: 'Cartel científico con defensa oral. Es la única modalidad de presentación.',
  },
  {
    pregunta: '¿Cuánto dura la presentación?',
    respuesta: 'De 5 a 10 minutos, más 3 a 5 minutos de preguntas del jurado.',
  },
  {
    pregunta: '¿Cuántos autores puede tener un trabajo?',
    respuesta: 'Máximo 5 autores; hasta 4 pueden presentar y defender el cartel.',
  },
  {
    pregunta: '¿Se puede enviar un protocolo en curso?',
    respuesta: 'Sí, se aceptan protocolos de investigación en curso.',
  },
  {
    pregunta: '¿Cómo sé si mi trabajo fue aceptado?',
    respuesta:
      'Se notifica por correo al autor de correspondencia. Se acepta con 21.0 puntos o más de 30, conforme a la rúbrica oficial.',
  },
] as const;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: preguntas.map((item) => ({
    '@type': 'Question',
    name: item.pregunta,
    acceptedAnswer: { '@type': 'Answer', text: item.respuesta },
  })),
};
---

<section id="faq" class="scroll-mt-20 py-20 md:py-28">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <SectionTitle eyebrow="Dudas">
      Preguntas <span class="text-gold-dark">frecuentes</span>
    </SectionTitle>

    <div class="mt-14 space-y-4">
      {
        preguntas.map((item) => (
          <details class="group rounded-2xl border border-navy/10 bg-card px-6 py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-navy [&::-webkit-details-marker]:hidden">
              {item.pregunta}
              <svg
                class="h-5 w-5 shrink-0 text-gold-dark transition-transform group-open:rotate-180"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-secondary">{item.respuesta}</p>
          </details>
        ))
      }
    </div>

    <p class="mt-10 text-center text-sm text-secondary">
      ¿Tienes otra duda? Escríbenos a{' '}
      <a href={`mailto:${SITE.contactEmail}`} class="font-medium text-gold-dark underline-offset-4 hover:underline">
        {SITE.contactEmail}
      </a>
    </p>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
