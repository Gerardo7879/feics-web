---
/**
 * Sección "¿Qué es FEICS?": descripción del foro + fotografía.
 */
import SectionTitle from './SectionTitle.astro';
---

<section id="que-es" class="scroll-mt-20 bg-card py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionTitle eyebrow="Conócenos">
      ¿Qué es <span class="text-gold-dark">FEICS</span>?
    </SectionTitle>

    <div class="mt-14 grid items-center gap-12 md:grid-cols-2">
      <p class="text-lg leading-relaxed text-secondary">
        FEICS es el Foro Estudiantil de Investigación en Ciencias de la Salud,
        un espacio académico donde estudiantes presentan investigaciones,
        intercambian ideas y fortalecen su formación científica mediante
        actividades de alto nivel.
      </p>

      <figure>
        <!-- [EDITAR] Reemplaza /images/foro.svg por una fotografía real del foro
             (ej. /images/foro.jpg) y actualiza el texto alternativo. -->
        <img
          src="/images/foro.svg"
          alt="Estudiantes presentando sus investigaciones durante el FEICS (imagen placeholder)"
          class="w-full rounded-2xl border border-navy/10"
          width="800"
          height="600"
          loading="lazy"
        />
      </figure>
    </div>
  </div>
</section>
