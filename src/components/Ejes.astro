---
/**
 * Ejes temáticos del foro: tarjetas con ícono de línea (marino/dorado),
 * título y descripción breve.
 */
import SectionTitle from './SectionTitle.astro';

const ejes = [
  {
    titulo: 'Medicina clínica y traslacional',
    descripcion:
      'Diagnóstico, tratamiento y estudios de caso que conectan la investigación con la práctica clínica.',
    icono: 'estetoscopio',
  },
  {
    titulo: 'Nutrición y salud metabólica',
    descripcion:
      'Alimentación, composición corporal, enfermedades crónicas y estrategias de intervención nutricional.',
    icono: 'nutricion',
  },
  {
    titulo: 'Salud pública y epidemiología',
    descripcion:
      'Prevención, determinantes sociales de la salud y análisis de poblaciones.',
    icono: 'comunidad',
  },
  {
    titulo: 'Ciencias biomédicas básicas',
    descripcion:
      'Investigación en fisiología, farmacología, microbiología y biología molecular.',
    icono: 'microscopio',
  },
  {
    titulo: 'Salud mental y bienestar',
    descripcion:
      'Abordajes psicológicos, calidad de vida y salud integral del paciente.',
    icono: 'mente',
  },
  {
    titulo: 'Innovación y tecnología en salud',
    descripcion:
      'Herramientas digitales, dispositivos y nuevos modelos educativos aplicados a las ciencias de la salud.',
    icono: 'innovacion',
  },
  {
    titulo: 'Divulgación científica',
    descripcion:
      'Comunicación del conocimiento en salud hacia la comunidad: estrategias, materiales y proyectos que acercan la ciencia a públicos no especializados.',
    icono: 'divulgacion',
  },
] as const;
---

<section id="ejes" class="scroll-mt-20 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionTitle eyebrow="Ejes temáticos">
      Áreas de <span class="text-gold-dark">investigación</span>
    </SectionTitle>

    <ul class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {
        ejes.map((eje) => (
          <li class="rounded-2xl border border-navy/10 bg-card p-7">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-cream text-gold-dark" aria-hidden="true">
              {eje.icono === 'estetoscopio' && (
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 3v6a5 5 0 0 0 10 0V3M5 3H4m2 0h1m7 0h-1m2 0h1" />
                  <path d="M10 14v2a5 5 0 0 0 10 0v-2" />
                  <circle cx="20" cy="12" r="2" />
                </svg>
              )}
              {eje.icono === 'nutricion' && (
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 8c-4 0-6 2.5-6 6s2.5 7 6 7 6-3.5 6-7-2-6-6-6z" />
                  <path d="M12 8V5m0 0c0-1.5 1.5-3 3-3 0 1.5-1.5 3-3 3z" />
                </svg>
              )}
              {eje.icono === 'comunidad' && (
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="7" r="3" />
                  <path d="M6 21v-1a6 6 0 0 1 12 0v1" />
                  <circle cx="4.5" cy="10" r="2" />
                  <circle cx="19.5" cy="10" r="2" />
                </svg>
              )}
              {eje.icono === 'microscopio' && (
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 3l4 4-5 5-4-4z" />
                  <path d="M10 10l2 2M5 21h14M8 21a7 7 0 1 1 11-5.7" />
                </svg>
              )}
              {eje.icono === 'mente' && (
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 4a6 6 0 0 1 6 6c0 1.5-.5 2.6-1.2 3.7-.5.8-.8 1.5-.8 2.3v1a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-1c0-.8-.3-1.5-.8-2.3C6.5 12.6 6 11.5 6 10a6 6 0 0 1 6-6z" />
                  <path d="M10 21h4" />
                </svg>
              )}
              {eje.icono === 'innovacion' && (
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="7" y="7" width="10" height="10" rx="2" />
                  <path d="M10 3v4m4-4v4M10 17v4m4-4v4M3 10h4m-4 4h4m10-4h4m-4 4h4" />
                </svg>
              )}
              {eje.icono === 'divulgacion' && (
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 10v4a1 1 0 0 0 1 1h2l6 4V5L7 9H5a1 1 0 0 0-1 1z" />
                  <path d="M17 9a4 4 0 0 1 0 6m2.5-8.5a8 8 0 0 1 0 11" />
                </svg>
              )}
            </span>
            <h3 class="mt-5 text-lg font-semibold text-navy">{eje.titulo}</h3>
            <p class="mt-2 text-sm leading-relaxed text-secondary">{eje.descripcion}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
