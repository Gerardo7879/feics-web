---
/**
 * Galería de ediciones pasadas. Estado actual: "Próximamente".
 * [EDITAR] Cuando tengas fotografías reales (public/images/galeria-N.jpg),
 * restaura el grid de imágenes con un alt descriptivo por foto.
 */
import SectionTitle from './SectionTitle.astro';
---

<section id="galeria" class="scroll-mt-20 bg-card py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionTitle eyebrow="Memorias">
      Ediciones <span class="text-gold-dark">pasadas</span>
    </SectionTitle>

    <div class="mx-auto mt-14 max-w-2xl rounded-2xl border border-dashed border-gold/50 bg-cream px-8 py-14 text-center">
      <span class="inline-block rounded-full bg-gold/15 px-4 py-1.5 text-sm font-bold uppercase tracking-brand text-gold-dark">
        Próximamente
      </span>
      <p class="mt-5 text-lg leading-relaxed text-secondary">
        Estamos preparando la galería con fotografías de ediciones anteriores del foro.
      </p>
    </div>
  </div>
</section>
